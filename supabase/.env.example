# Secrets para las Edge Functions de Supabase
# Configurar con: npx supabase secrets set KEY=value
# Listar actuales: npx supabase secrets list

# API-Football (direct) — https://dashboard.api-football.com
APIFOOTBALL_KEY=your-api-football-key

# RapidAPI — https://rapidapi.com (usado por sync-results, sync-premier, sync-sofascore, player-photos)
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=fotmob-api.p.rapidapi.com   # opcional, valor por defecto

# FotMob league ID para el Mundial (opcional, por defecto 77)
WC_FOTMOB_LEAGUE_ID=77

# SUPABASE_URL y SUPABASE_SERVICE_ROLE_KEY son inyectados automáticamente por Supabase
# No es necesario configurarlos manualmente
