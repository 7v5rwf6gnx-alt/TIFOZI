# Copiar a .env y completar con valores reales
# NUNCA commitear el archivo .env

PORT=3000

# URL del frontend (separar con coma si hay múltiples, ej: producción y dev)
FRONTEND_URL=http://localhost:5173

# Supabase — obtener en dashboard.supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # ⚠️  SECRETO — nunca al frontend
